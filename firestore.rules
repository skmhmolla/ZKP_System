


rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isIssuerAdmin() {
      // In this system, we use a simple check or look up the user's role in the /users collection
      // For performance in rules, we can check if the email is in a known admin list (if passed in claims)
      // or check the Firestore document.
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'issuer_admin' ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    // 1. User Profiles
    match /users/{userId} {
      allow read: if isOwner(userId) || isIssuerAdmin();
      allow write: if isOwner(userId) || isIssuerAdmin();
    }
    
    // 2. Verification Requests
    match /verification_requests/{requestId} {
      allow create: if isAuthenticated();
      allow read: if isAuthenticated() && (resource.data.userUID == request.auth.uid || isIssuerAdmin());
      allow update, delete: if isIssuerAdmin();
    }
    
    // 3. Holder Credentials
    match /holder_credentials/{credId} {
      allow read: if isAuthenticated() && (resource.data.holderUID == request.auth.uid || isIssuerAdmin());
      allow write: if isIssuerAdmin();
    }
    
    // 4. Audit Logs & Revocations
    match /audit_logs/{logId} {
      allow read, write: if isIssuerAdmin();
    }
    
    match /revocations/{id} {
      allow read: if isAuthenticated();
      allow write: if isIssuerAdmin();
    }
    
    // 5. Issuer Settings
    match /issuer_settings/{id} {
      allow read: if isAuthenticated();
      allow write: if isIssuerAdmin();
    }

    // 6. Wallet Activity (History)
    match /wallet_activity/{logId} {
      allow read, write: if isAuthenticated() && (resource == null || resource.data.userUID == request.auth.uid || request.resource.data.userUID == request.auth.uid);
    }

    // 7. ZK Proofs
    match /zk_proofs/{id} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.holderUID == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.holderUID == request.auth.uid;
    }

    // Default deny for everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
