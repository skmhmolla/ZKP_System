rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // User Profiles (Holders)
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Verifier Organizations
    match /verifiers/{verifierId} {
      // Verifiers can read their own profile. Admin can read all.
      allow read: if request.auth != null && (request.auth.uid == verifierId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
      
      // Only system or admin can create/approve verifiers
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // Admin Specific Data
    match /admin_data/{docId} {
      allow read, write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
